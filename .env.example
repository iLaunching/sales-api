# Sales API Environment Configuration

# Application
DEBUG=true
PORT=8080
ENVIRONMENT=development

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-frontend-domain.com

# PostgreSQL Database (REQUIRED)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sales_db
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# Redis Session Store (REQUIRED)
REDIS_URL=redis://localhost:6379/0
REDIS_SESSION_TTL=86400  # 24 hours in seconds

# Qdrant Vector Database (OPTIONAL - Phase 1)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here
QDRANT_COLLECTION_NAME=sales_knowledge
QDRANT_ENABLED=false  # Set to true when Qdrant is configured

# LLM Configuration (OPTIONAL - needed for AI responses)
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here
DEFAULT_LLM_MODEL=gpt-4o-mini
TEMPERATURE=0.7
MAX_TOKENS=1000

# MCP Server (OPTIONAL - Phase 1)
MCP_SERVER_URL=http://localhost:8081
MCP_SERVER_TIMEOUT=30
MCP_ENABLED=false  # Set to true when MCP server is configured

# Auth API Integration (OPTIONAL - Phase 3)
AUTH_API_URL=http://localhost:8000
AUTH_API_KEY=your_auth_api_key_here

# Lead Qualification Thresholds
HIGH_QUALITY_SCORE_THRESHOLD=70
MEDIUM_QUALITY_SCORE_THRESHOLD=40

# A/B Testing
AB_TESTING_ENABLED=true
AB_TEST_VARIANTS=control,variant_a,variant_b

# Analytics
CONVERSION_TRACKING_ENABLED=true
ANALYTICS_BATCH_SIZE=100

# Monitoring
SENTRY_DSN=your_sentry_dsn_here
LOG_LEVEL=INFO
